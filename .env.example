# Local development (SQLite file)
DATABASE_URL=file:local.db

# Production (Turso via Vercel Marketplace — auto-set when you connect a database)
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Email Configuration (Resend)
# Get your API key from https://resend.com/api-keys
# If not set, OTP codes will be logged to console instead
RESEND_API_KEY=""

# The "from" email address for sending emails
# Must be a verified domain in Resend, or use "onboarding@resend.dev" for testing
EMAIL_FROM="Journal Thingy <onboarding@resend.dev>"

# UploadThing — get your token from https://uploadthing.com/dashboard
UPLOADTHING_TOKEN=""
